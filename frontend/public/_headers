# Headers para hosts estilo Netlify/Render Static Site.
# index.html e version.json nunca devem ficar em cache longo.

/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

/version.json
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable
