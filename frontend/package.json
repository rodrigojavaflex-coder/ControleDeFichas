{
  "name": "frontend",
  "version": "1.6.0",
  "scripts": {
    "prebuild": "node ./scripts/ensure-prod-env.mjs && node ./scripts/generate-version.mjs",
    "prestart": "node ./scripts/generate-version.mjs",
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.json",
    "build": "npx ng build",
    "watch": "ng build --watch --configuration development",
    "generate-version": "node ./scripts/generate-version.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "overrides": {
    "ws": "8.20.1"
  },
  "dependencies": {
    "@angular/common": "21.2.13",
    "@angular/compiler": "21.2.13",
    "@angular/core": "21.2.13",
    "@angular/forms": "21.2.13",
    "@angular/platform-browser": "21.2.13",
    "@angular/router": "21.2.13",
    "bootstrap": "^5.3.8",
    "chart.js": "^4.5.1",
    "exceljs": "^4.4.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "21.2.11",
    "@angular/cli": "21.2.11",
    "@angular/compiler-cli": "21.2.13",
    "@types/bootstrap": "^5.2.10",
    "baseline-browser-mapping": "^2.9.17",
    "typescript": "~5.9.2"
  }
}
