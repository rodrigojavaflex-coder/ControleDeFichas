# Copie para .env e preencha os valores reais (nunca commitar .env)
# Referência de nomes para desenvolvedores e agente IA — sem segredos.

# Configurações da aplicação
NODE_ENV=development
PORT=3000

# Configurações do banco de dados PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_NAME=
DATABASE_SYNCHRONIZE=false

# Configuração de logging do banco (true = todos os logs SQL, false = apenas erros/warnings/migrations)
DATABASE_LOGGING=false

# JWT Secret (gere uma chave segura em produção)
JWT_SECRET=
JWT_EXPIRES_IN=6h

# Configurações do Swagger
SWAGGER_TITLE=NestJS Angular API
SWAGGER_DESCRIPTION=API para projeto NestJS + Angular
SWAGGER_VERSION=1.0

# CONFIGURAÇÕES WHATSAPP
WHATSAPP_ENABLED=false
WHATSAPP_API_VERSION=v25.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_TEMPLATE_RECIBO_NAME=
WHATSAPP_TEMPLATE_RECIBO_LANG=pt_BR
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_CONTATO_DUVIDAS_NOME=
WHATSAPP_CONTATO_DUVIDAS_NUMERO=
# Webhook (fase M5 — ver docs/WHATSAPP_WEBHOOK.md)
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_ENABLED=false
# Opcional: caminho alternativo do conversor de áudio (padrão: pacote embutido ffmpeg-static)
# WHATSAPP_FFMPEG_PATH=
# Retenção da mídia de atendimento no banco (dias). Após expirar, o binário é removido (metadados permanecem).
WHATSAPP_MEDIA_RETENCAO_DIAS=30

# CONFIGURAÇÕES AGENTES (sincronização / IA por unidade)
AGENTE_INHUMAS_URL=
AGENTE_INHUMAS_TOKEN=
AGENTE_NEROPOLIS_URL=
AGENTE_NEROPOLIS_TOKEN=
AGENTE_UBERABA_URL=
AGENTE_UBERABA_TOKEN=
